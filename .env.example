# ===== OpenAI API =====
OPENAI_API_KEY=sk-your-key-here

# ===== Embedding & Chunking =====
EMB_ADAPTER=openai
EMB_MODEL=text-embedding-3-small
USE_TIKTOKEN=1
CHUNK_MAX_TOKENS=512
CHUNK_OVERLAP=128

# ===== Vector Store =====
FAISS_INDEX_PATH=data/embeddings/vectors.faiss
FAISS_IDS_PATH=data/embeddings/ids.npy

# ===== LLM =====
LLM_ADAPTER=openai
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=600

# ===== Reranker =====
RERANK_ADAPTER=openai_reranker
RERANK_MODEL=text-embedding-3-large
RERANK_TOPN=20

# ===== Database =====
SQLITE_DB_PATH=data/knowledge_hub.db

# ===== PDF Processing =====
PDF_ROOT=data/raw
PDF_ASSETS_DIR=data/assets
DOCLING_DEVICE=cpu  # cpu | mps (use cpu for stability)

# ===== API Server =====
HOST=0.0.0.0
PORT=8000

# ===== Retrieval =====
RETRIEVAL_K=6
RETRIEVAL_NEIGHBORS=1
RETRIEVAL_DIVERSE_PER_DOC=true

# ===== Azure Document Intelligence =====
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_KEY=your-azure-key

# ===== PostgreSQL =====
POSTGRES_CONNECTION_STRING=postgresql+psycopg2://postgres:password@localhost:5432/knowledge_hub
