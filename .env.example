# Server
HOST=0.0.0.0
PORT=8000
UI_PORT=8501
COTTON_API_BASE=http://localhost:8000/api
COTTON_RUNTIME=configs/runtime/openai.yaml

# Retrieval
RETRIEVAL_MODE=dense   # dense | bm25 | hybrid
RERANK=false

# Models
EMB_MODEL=text-embedding-3-small
RERANK_MODEL=text-embedding-3-large

# LLM (pick ONE path)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# OR local Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3:8b-instruct

# LangChain overrides (optional)
# LC_USE_CHAT_OPENAI=1
# LC_CHAT_BACKUP_MODEL=gpt-4o-mini
# LC_USE_MULTIQUERY=1
# LC_USE_COMPRESSION=1
# LC_CANDIDATE_MULTIPLIER=8
# LC_CANDIDATE_MIN=48
# LC_CANDIDATE_LIMIT=64
# LC_CANDIDATE_OVERFETCH_FACTOR=1.6
