# =============================================================================
# AI Knowledge Hub - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=knowledge_hub
POSTGRES_CONNECTION_STRING=postgresql://postgres:your_secure_password_here@localhost:5432/knowledge_hub

# -----------------------------------------------------------------------------
# API Security
# -----------------------------------------------------------------------------
# API key for authenticating requests (generate a secure random string)
# Example: openssl rand -hex 32
API_KEY=your_api_key_here

# Set to "production" in production deployments
ENVIRONMENT=development

# -----------------------------------------------------------------------------
# OpenAI Configuration
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key-here

# -----------------------------------------------------------------------------
# Azure Document Intelligence (for PDF parsing)
# -----------------------------------------------------------------------------
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_KEY=your_azure_key_here

# -----------------------------------------------------------------------------
# LangSmith Tracing (optional)
# -----------------------------------------------------------------------------
LANGSMITH_API_KEY=
LANGCHAIN_PROJECT=crdc-knowledge-hub

# -----------------------------------------------------------------------------
# CORS Configuration (comma-separated origins for production)
# -----------------------------------------------------------------------------
# Example: CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
CORS_ORIGINS=

# -----------------------------------------------------------------------------
# Runtime Configuration
# -----------------------------------------------------------------------------
COTTON_RUNTIME=configs/runtime/openai.yaml

# -----------------------------------------------------------------------------
# PDF Storage
# -----------------------------------------------------------------------------
PDF_ROOT=data/raw_ingest
