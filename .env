# Server
HOST=0.0.0.0
PORT=8000
UI_PORT=8501
COTTON_API_BASE=http://localhost:8000/api
COTTON_RUNTIME=configs/runtime/openai.yaml

# Retrieval
RETRIEVAL_MODE=dense   # dense | bm25 | hybrid
RERANK=false

# Models
EMB_ADAPTER=openai
EMB_MODEL=text-embedding-3-small
RERANK_MODEL=text-embedding-3-large

# LLM (pick ONE path)
OPENAI_API_KEY=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
