# Consolidated Runtime Configuration for CRDC Knowledge Hub
# Single source of truth for all RAG components

# ===== OPENAI CONFIGURATION =====
OPENAI_API_KEY=sk-...  # Set from .env file

# ===== EMBEDDINGS =====
EMB_ADAPTER=openai
EMB_MODEL=text-embedding-3-small
USE_TIKTOKEN=1  # Use OpenAI's tiktoken for chunking (matches embedding model)

# ===== CHUNKING =====  
CHUNK_MAX_TOKENS=512
CHUNK_OVERLAP=128

# ===== VECTOR STORE =====
FAISS_INDEX_PATH=data/embeddings/vectors.faiss
FAISS_IDS_PATH=data/embeddings/ids.npy

# ===== LLM =====
LLM_ADAPTER=openai
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=600

# ===== RERANKER =====
RERANK_ADAPTER=openai_reranker  
RERANK_MODEL=text-embedding-3-large
RERANK_TOPN=20

# ===== RETRIEVAL =====
RETRIEVAL_K=6
RETRIEVAL_NEIGHBORS=1
RETRIEVAL_DIVERSE_PER_DOC=true

# ===== DATABASE =====
SQLITE_DB_PATH=data/knowledge_hub.db

# ===== PDF STORAGE =====
PDF_ROOT=data/raw
PDF_ASSETS_DIR=data/assets
